# ── AimFiinsight Annual-Report → Excel · environment ────────────────────────
# Copy to ".env" for local dev, or set these as environment variables on Render.
# EVERY value here is optional — the app runs fully without any of them
# (email signups fall back to a local signups.csv, and AI assist stays off).

# Stable secret that signs the "signed-up" session cookie. Set a long random
# string in production so the signup gate survives restarts/redeploys.
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# ── Email storage: Google Form -> linked Google Sheet (your mailing list) ───
# Signups POST to a published Google Form (email collection OFF, "Anyone with
# the link"); responses land in the form's linked Sheet. No credentials needed.
#   FORM_POST_URL    -> the form's .../formResponse URL
#   FORM_EMAIL_ENTRY -> the email field id (e.g. entry.906489358)
#   FORM_NAME_ENTRY  -> the name field id  (e.g. entry.659201863), optional
FORM_POST_URL=
FORM_EMAIL_ENTRY=
FORM_NAME_ENTRY=

# ── AI-assisted extraction (A2E-grade) ─────────────────────────────────────
# PREFERRED: Claude (the A2E gold standard). Key from
# https://console.anthropic.com/settings/keys (paid; ~$0.10/conversion on
# Sonnet, ~$0.50 on Opus). Set CLAUDE_MODEL=claude-opus-4-8 to match the chat
# output exactly, or leave default for the cheaper, near-identical Sonnet.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# FALLBACK: Google Gemini (used only when no Anthropic key is set).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Misc (sensible defaults already baked in) ───────────────────────────────
# OUTPUT_TTL_SECONDS=21600
# PORT=5050
