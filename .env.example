# ── AimFiinsight Annual-Report → Excel · environment ────────────────────────
# Copy to ".env" for local dev, or set these as environment variables on Render.
# EVERY value here is optional — the app runs fully without any of them
# (email signups fall back to a local signups.csv, and AI assist stays off).

# Stable secret that signs the "signed-up" session cookie. Set a long random
# string in production so the signup gate survives restarts/redeploys.
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# ── Google Sheets email storage (your mailing list) ─────────────────────────
# 1. console.cloud.google.com → new project → enable "Google Sheets API".
# 2. Create a Service Account → add a JSON key → download it.
# 3. Open your target Google Sheet → Share it (Editor) with the service
#    account's client_email (looks like ...@...iam.gserviceaccount.com).
# 4. Put the spreadsheet ID (the long token in its URL) in SHEET_ID below.
# 5. Paste the WHOLE service-account JSON on one line in
#    GOOGLE_SERVICE_ACCOUNT_JSON (or give a path to the .json file).
SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Optional AI-assisted extraction (free Google AI Studio / Gemini) ────────
# Free key from https://aistudio.google.com/apikey . Only used when a visitor
# ticks "AI-assisted extraction" AND the on-server parser had low confidence.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Misc (sensible defaults already baked in) ───────────────────────────────
# OUTPUT_TTL_SECONDS=21600
# PORT=5050
